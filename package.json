{
  "name": "little-alchemist-2-cheats",
  "version": "1.15.1",
  "homepage": "https://manix84.github.io/little-alchemist-2-cheats",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.10.4",
    "@emotion/styled": "^11.10.4",
    "@mdi/js": "^7.4.47",
    "@mui/material": "^5.10.6",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.4",
    "styled-components": "^5.3.6"
  },
  "scripts": {
    "start": "vite",
    "build": "tsc --noEmit && vite build",
    "build:dry-run": "node scripts/dry-run-build.mjs",
    "check": "npm run lint && npm run typecheck && npm test && npm run build:dry-run",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "data:refresh": "node scripts/refresh-data.mjs",
    "assets:download": "node scripts/download-assets.mjs",
    "pwa:verify": "node scripts/verify-pwa-offline.mjs",
    "prepare": "git config core.hooksPath .githooks",
    "version:bump": "node scripts/smart-version-bump.mjs"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^13.4.0",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.0.21",
    "@types/react-dom": "^18.0.6",
    "@types/styled-components": "^5.1.26",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^27.2.0",
    "prettier": "^2.7.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^7.2.6",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.0.15"
  }
}
